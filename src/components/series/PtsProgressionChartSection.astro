---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { PtsProgressionAreaChart } from "@/components/PtsProgressionAreaChart";
import { api, type PtsProgression } from "@/lib/api";

export type PtsProgressionChartSectionProps = {
  seriesId: string;
  gameRange: string | null;
};

const { seriesId, gameRange } = Astro.props as PtsProgressionChartSectionProps;

// Fetch pts progression at component level with optional game range filter
const maxGameNumber = gameRange ? parseInt(gameRange) : undefined;
const ptsProgression = await api.getSeriesPtsProgression(seriesId, maxGameNumber) as PtsProgression[];
---

<Card>
  <CardHeader>
    <CardTitle>Points Progression</CardTitle>
    <CardDescription>How points evolved across games</CardDescription>
  </CardHeader>
  <CardContent>
    <PtsProgressionAreaChart progression={ptsProgression} client:visible />
  </CardContent>
</Card>