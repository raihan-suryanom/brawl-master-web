---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { WinRatePieChart } from "@/components/WinRatePieChart";
import { api, type PlayerStats } from "@/lib/api";

export type WinRatePieChartSectionProps = {
  seriesId: string;
  gameRange: string | null;
};

const { seriesId, gameRange } = Astro.props as WinRatePieChartSectionProps;

// Fetch stats at component level with optional game range filter
const maxGameNumber = gameRange ? parseInt(gameRange) : undefined;
const stats = await api.getSeriesStats(seriesId, maxGameNumber) as PlayerStats[];
---

<Card>
  <CardHeader>
    <CardTitle>Win Distribution</CardTitle>
    <CardDescription>Wins by player</CardDescription>
  </CardHeader>
  <CardContent>
    <WinRatePieChart stats={stats} client:visible />
  </CardContent>
</Card>