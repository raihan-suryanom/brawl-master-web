---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { api, type Game } from "@/lib/api";

export type GamesListSectionProps = {
  seriesId: string;
  gameRange: string | null;
};

const { seriesId, gameRange } = Astro.props as GamesListSectionProps;

// Fetch games at component level with optional game range filter
const maxGameNumber = gameRange ? parseInt(gameRange) : undefined;
const games = await api.getGames(seriesId, maxGameNumber) as Game[];

// Helper to sort players alphabetically
const sortPlayers = (players: any[]) => {
  return [...players].sort((a, b) => a.name.localeCompare(b.name));
};
---

<Card>
  <CardHeader>
    <CardTitle>Match History</CardTitle>
    <CardDescription>{games.length} game{games.length !== 1 ? 's' : ''} played</CardDescription>
  </CardHeader>
  <CardContent>
    <!-- Horizontal scroll container -->
    <div class="overflow-x-auto pb-4">
      <div class="flex gap-4 min-w-min">
        {games.map((game) => {
          const sortedBlue = sortPlayers(game.teamBlue);
          const sortedRed = sortPlayers(game.teamRed);
          const blueWins = game.winner === 'teamBlue';
          const redWins = game.winner === 'teamRed';
          
          return (
            <div class="flex-shrink-0 w-[200px] border rounded-lg overflow-hidden">
              <!-- Game header -->
              <div class="bg-muted px-3 py-2 border-b">
                <div class="text-sm font-semibold text-center">Game {game.gameNumber}</div>
              </div>
              
              <!-- Team Blue -->
              <div class={`p-3 ${blueWins ? 'bg-blue-50 dark:bg-blue-950/30' : ''}`}>
                <div class="text-xs font-medium mb-2 text-blue-600 dark:text-blue-400 flex items-center justify-between">
                  <span>Blue</span>
                  {blueWins && <span class="text-lg">✓</span>}
                </div>
                <div class="space-y-1.5">
                  {sortedBlue.map((player) => (
                    <div class="flex items-center gap-1.5 text-xs">
                      <img 
                        src={player.picture} 
                        alt={player.name} 
                        class="w-4 h-4 rounded-full object-cover flex-shrink-0"
                      />
                      <span class={blueWins ? 'font-medium' : ''}>{player.name}</span>
                    </div>
                  ))}
                </div>
              </div>
              
              <!-- Divider -->
              <div class="border-t" />
              
              <!-- Team Red -->
              <div class={`p-3 ${redWins ? 'bg-red-50 dark:bg-red-950/30' : ''}`}>
                <div class="text-xs font-medium mb-2 text-red-600 dark:text-red-400 flex items-center justify-between">
                  <span>Red</span>
                  {redWins && <span class="text-lg">✓</span>}
                </div>
                <div class="space-y-1.5">
                  {sortedRed.map((player) => (
                    <div class="flex items-center gap-1.5 text-xs">
                      <img 
                        src={player.picture} 
                        alt={player.name} 
                        class="w-4 h-4 rounded-full object-cover flex-shrink-0"
                      />
                      <span class={redWins ? 'font-medium' : ''}>{player.name}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
    
    {games.length === 0 && (
      <div class="text-center py-8 text-muted-foreground">
        No games played yet
      </div>
    )}
  </CardContent>
</Card>