---
import { api, type Series } from "@/lib/api";
import { SeriesNavigation } from "./SeriesNavigation";

export type SeriesHeaderProps = {
  seriesId: string;
  gameRange: string | null;
};

const { seriesId } = Astro.props as SeriesHeaderProps;

// Fetch all series for navigation
const allSeries = await api.getSeries() as Series[];
---

<div>
  <!-- Series Navigation (Prev/Next only) -->
  <SeriesNavigation 
    allSeries={allSeries}
    currentSeriesId={seriesId}
    client:visible
  />
</div>