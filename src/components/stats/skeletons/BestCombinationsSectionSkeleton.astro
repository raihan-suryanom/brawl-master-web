---
import { Card, CardContent, CardHeader } from "@/components/ui/card";
---
<>
  <!-- Best Duo Combinations Skeleton -->
  <Card>
    <CardHeader>
      <div class="space-y-2 animate-pulse">
        <div class="h-6 w-56 bg-muted rounded"></div>
        <div class="h-4 w-80 bg-muted rounded"></div>
      </div>
    </CardHeader>
    <CardContent>
      <div class="space-y-3 animate-pulse">
        <!-- Table header -->
        <div class="grid grid-cols-5 gap-4 pb-2 border-b">
          {[1, 2, 3, 4, 5].map(() => (
            <div class="h-4 w-16 bg-muted rounded"></div>
          ))}
        </div>
        
        <!-- Table rows -->
        {[1, 2, 3, 4, 5].map(() => (
          <div class="grid grid-cols-5 gap-4 items-center py-3">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-muted"></div>
              <div class="w-8 h-8 rounded-full bg-muted"></div>
            </div>
            <div class="h-4 w-16 bg-muted rounded"></div>
            <div class="h-4 w-8 bg-muted rounded"></div>
            <div class="h-4 w-8 bg-muted rounded"></div>
            <div class="h-4 w-12 bg-muted rounded"></div>
          </div>
        ))}
      </div>
    </CardContent>
  </Card>

  <!-- Best Trio Combinations Skeleton -->
  <Card>
    <CardHeader>
      <div class="space-y-2 animate-pulse">
        <div class="h-6 w-56 bg-muted rounded"></div>
        <div class="h-4 w-80 bg-muted rounded"></div>
      </div>
    </CardHeader>
    <CardContent>
      <div class="space-y-3 animate-pulse">
        <!-- Table header -->
        <div class="grid grid-cols-5 gap-4 pb-2 border-b">
          {[1, 2, 3, 4, 5].map(() => (
            <div class="h-4 w-16 bg-muted rounded"></div>
          ))}
        </div>
        
        <!-- Table rows -->
        {[1, 2, 3, 4, 5].map(() => (
          <div class="grid grid-cols-5 gap-4 items-center py-3">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-full bg-muted"></div>
              <div class="w-8 h-8 rounded-full bg-muted"></div>
              <div class="w-8 h-8 rounded-full bg-muted"></div>
            </div>
            <div class="h-4 w-16 bg-muted rounded"></div>
            <div class="h-4 w-8 bg-muted rounded"></div>
            <div class="h-4 w-8 bg-muted rounded"></div>
            <div class="h-4 w-12 bg-muted rounded"></div>
          </div>
        ))}
      </div>
    </CardContent>
  </Card>
</>