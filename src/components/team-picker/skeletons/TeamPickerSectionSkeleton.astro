---
import { Card, CardContent, CardHeader } from "@/components/ui/card";
---

<div class="space-y-6">
  <!-- Series selection card skeleton -->
  <Card>
    <CardHeader>
      <div class="space-y-2 animate-pulse">
        <div class="h-6 w-32 bg-muted rounded"></div>
        <div class="h-4 w-56 bg-muted rounded"></div>
      </div>
    </CardHeader>
    <CardContent>
      <div class="space-y-4 animate-pulse">
        <div class="space-y-2">
          <div class="h-4 w-16 bg-muted rounded"></div>
          <div class="h-10 w-full bg-muted rounded"></div>
        </div>
        <div class="h-4 w-40 bg-muted rounded"></div>
        <div class="h-12 w-full bg-muted rounded"></div>
      </div>
    </CardContent>
  </Card>

  <!-- Team result skeleton -->
  <Card>
    <CardHeader>
      <div class="space-y-2 animate-pulse">
        <div class="h-6 w-32 bg-muted rounded"></div>
        <div class="h-4 w-48 bg-muted rounded"></div>
      </div>
    </CardHeader>
    <CardContent>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 animate-pulse">
        <!-- Team Blue skeleton -->
        <div class="space-y-3">
          <div class="text-center space-y-2">
            <div class="h-7 w-28 bg-muted rounded mx-auto"></div>
            <div class="h-4 w-20 bg-muted rounded mx-auto"></div>
          </div>
          <div class="border-2 rounded-lg p-4 space-y-2">
            {[1, 2, 3].map(() => (
              <div class="flex items-center gap-3 p-2 rounded border">
                <div class="w-10 h-10 rounded-full bg-muted"></div>
                <div class="h-4 w-24 bg-muted rounded"></div>
              </div>
            ))}
          </div>
        </div>

        <!-- Team Red skeleton -->
        <div class="space-y-3">
          <div class="text-center space-y-2">
            <div class="h-7 w-28 bg-muted rounded mx-auto"></div>
            <div class="h-4 w-20 bg-muted rounded mx-auto"></div>
          </div>
          <div class="border-2 rounded-lg p-4 space-y-2">
            {[1, 2, 3].map(() => (
              <div class="flex items-center gap-3 p-2 rounded border">
                <div class="w-10 h-10 rounded-full bg-muted"></div>
                <div class="h-4 w-24 bg-muted rounded"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </CardContent>
  </Card>
</div>
